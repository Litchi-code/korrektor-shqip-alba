<!DOCTYPE html>
<html lang="sq">
<head>
<meta charset="UTF-8">
<title>Shkruani shqipen pa gabime - ALBA</title>

<style>
body {
  font-family: Arial;
  padding: 40px;
  background: #f5f5f5;
}

textarea {
  width: 100%;
  height: 150px;
  font-size: 16px;
}

button {
  margin-top: 10px;
  padding: 10px;
  background: #27ae60;
  color: white;
  border: none;
  cursor: pointer;
}

#output {
  background: white;
  padding: 15px;
  margin-top: 20px;
}

.error {
  color: red;
}
</style>
</head>

<body>

<h1>Shkruani shqipen pa gabime<br><small>Shoqata ALBA</small></h1>

<textarea id="text" placeholder="Shkruaj këtu..."></textarea><br>

<button onclick="correct()">Korrigjo</button>

<div id="output"></div>

<script>
async function correct() {
  const text = document.getElementById("text").value;
  const output = document.getElementById("output");

  if (!text) {
    output.innerHTML = "<p class='error'>Shkruaj diçka!</p>";
    return;
  }

  output.innerHTML = "⏳ Duke korrigjuar...";

  try {
    const res = await fetch("http://localhost:3000/correct", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ text })
    });

    const data = await res.json();

    output.innerHTML = `
      <h3>Teksti i korrigjuar</h3>
      <p>${data.corrected}</p>

      <h3>Shpjegime</h3>
      ${data.explanations.map(e => `<p>• ${e}</p>`).join("")}
    `;

  } catch (err) {
    output.innerHTML = "<p class='error'>❌ Server nuk po përgjigjet</p>";
  }
}
</script>

</body>
</html>
